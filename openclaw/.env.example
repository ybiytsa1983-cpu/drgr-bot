# ========================
# Telegram Bot
# ========================
BOT_TOKEN=your_telegram_bot_token_here

# ========================
# PostgreSQL
# ========================
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw_secret
POSTGRES_DB=openclaw
DATABASE_URL=postgresql+asyncpg://openclaw:openclaw_secret@postgres:5432/openclaw

# ========================
# Redis
# ========================
REDIS_URL=redis://redis:6379/0

# ========================
# Wildberries API
# ========================
WB_API_KEY=your_wildberries_api_key_here
WB_API_URL=https://suppliers-api.wildberries.ru
WB_SEARCH_URL=https://search.wb.ru
WB_STATS_URL=https://statistics-api.wildberries.ru

# ========================
# MPStats API
# ========================
MPSTATS_API_KEY=your_mpstats_api_key_here
MPSTATS_API_URL=https://mpstats.io/api

# ========================
# Alibaba / 1688
# ========================
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret

# ========================
# OpenClaw / Ollama (AI agent)
# ========================
# When running locally (outside Docker):
# OLLAMA_URL=http://localhost:11434
# When running inside Docker Compose (default):
OLLAMA_URL=http://ollama:11434
AI_MODEL=llama3

# Or use OpenAI-compatible API:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# ========================
# Internal service URLs
# ========================
API_URL=http://api:8000

# ========================
# Scraper settings
# ========================
SCRAPER_INTERVAL_HOURS=6
SCRAPER_CATEGORIES=одежда,электроника,косметика,товары для дома
MAX_PRODUCTS_PER_CATEGORY=200

# ========================
# Unit economics defaults
# ========================
DEFAULT_WB_COMMISSION_PCT=15.0
DEFAULT_LOGISTICS_RUB=150.0
DEFAULT_STORAGE_RATE=0.15
DEFAULT_RETURN_RATE=0.10
