__pycache__/
*.pyc
*.pyo
.env
*.log
server.pid
.venv/
venv/
# Runtime data — generated by the agent and VM at runtime
vm/training_data/actions.jsonl
vm/training_data/image_descriptions.jsonl
screenshots/
articles/
# Generated projects (runtime output, not source code)
vm/projects/*
!vm/projects/.gitkeep
!vm/projects/.gitignore
nohup.out
# VM runtime state — updated by the server on every run
vm/instructions.json
# Auto-generated SSL certificate (created by vm.ps1 on first run)
ssl_cert.pem
ssl_key.pem
# Uploaded APK files (runtime uploads, not source code)
vm/static/android_apks/
