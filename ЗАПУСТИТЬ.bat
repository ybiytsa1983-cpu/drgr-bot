@echo off
chcp 65001 >nul
setlocal

:: ═══════════════════════════════════════════════════════════════════
::  ЗАПУСТИТЬ.bat  -  Запуск drgr-bot
::  Дважды щёлкните по этому файлу, чтобы запустить бота.
:: ═══════════════════════════════════════════════════════════════════

title drgr-bot - Запуск

set "SCRIPT_DIR=%~dp0"
cd /d "%SCRIPT_DIR%"

echo.
echo ╔══════════════════════════════════════════════╗
echo ║          drgr-bot  -  Запуск бота            ║
echo ╚══════════════════════════════════════════════╝
echo.

:: Проверяем наличие .env
if not exist "%SCRIPT_DIR%.env" (
    echo  [ОШИБКА] Файл .env не найден!
    echo  Сначала запустите УСТАНОВИТЬ.bat для первоначальной настройки.
    echo.
    pause
    exit /b 1
)

:: Проверяем незаполненные токены
findstr /i "BOT_TOKEN=ВАШ_ТОКЕН_БОТА" "%SCRIPT_DIR%.env" >nul 2>&1
if %errorlevel% EQU 0 (
    echo  [ОШИБКА] Токен бота не заполнен в .env!
    echo  Откройте .env и замените "ВАШ_ТОКЕН_БОТА" на реальный токен.
    echo.
    pause
    exit /b 1
)

:: Проверяем наличие bot.py
if not exist "%SCRIPT_DIR%bot.py" (
    echo  [ОШИБКА] bot.py не найден в %SCRIPT_DIR%
    echo  Убедитесь, что вы не переместили этот файл из папки бота.
    echo.
    pause
    exit /b 1
)

echo  Запуск bot.py...
echo  Чтобы остановить бота - закройте это окно.
echo.
python "%SCRIPT_DIR%bot.py"

echo.
echo  Бот остановлен. Нажмите любую клавишу для закрытия...
pause >nul
