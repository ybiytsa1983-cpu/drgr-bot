# ─────────────────────────────────────────────────────────────────────────────
#  drgr-bot — шаблон переменных окружения
#  Скопируйте этот файл в .env и заполните своими значениями:
#      copy .env.example .env        (cmd)
#      Copy-Item .env.example .env   (PowerShell)
# ─────────────────────────────────────────────────────────────────────────────

# [ОБЯЗАТЕЛЬНО] Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=ВАШ_ТОКЕН_БОТА

# [ОБЯЗАТЕЛЬНО] API-ключ Hugging Face (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=ВАШ_КЛЮЧ_HUGGINGFACE

# ── Директории (необязательно, по умолчанию указаны рядом) ────────────────────
PHOTOS_DIR=photos
VIDEOS_DIR=videos
GALLERY_DIR=gallery
FRAME_DIR=frames
COLLAGE_DIR=collages
FRAME_OVERLAY_DIR=frame_overlays
LOG_FILE=actions.log

# ── Лимиты (необязательно) ────────────────────────────────────────────────────
MAX_SIZE_MB=15
MAX_COMMENTS=20
