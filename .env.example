# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ─── Ollama (local AI) ────────────────────────────────────────────────────────
# URL of your running Ollama instance
OLLAMA_HOST=http://localhost:11434
# Default text model (any model you have pulled with `ollama pull <model>`)
OLLAMA_MODEL=llama2
# Default vision model for image descriptions (pull with `ollama pull llava`)
OLLAMA_VISION_MODEL=llava

# ─── VM Server ────────────────────────────────────────────────────────────────
# Base URL of the Flask VM server (vm/server.py)
VM_BASE=http://localhost:5000
VM_PORT=5000

# ─── Agent behaviour ──────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
MAX_SCREENSHOTS=2
# Auto-trigger self-improvement cycle after this many agent actions
RETRAIN_AFTER_ACTIONS=10

# ─── Directories ──────────────────────────────────────────────────────────────
SCREENSHOTS_DIR=screenshots
ARTICLES_DIR=articles
LOG_FILE=bot.log
