# =====================================================================
#  DRGR Bot — файл конфигурации
#  Скопируйте этот файл как .env и заполните нужные значения:
#    copy .env.example .env
# =====================================================================

# ── Telegram Bot ──────────────────────────────────────────────────────
# Получить токен: https://t.me/BotFather → /newbot
BOT_TOKEN=ВАШ_ТОКЕН_ЗДЕСЬ

# ── DRGR VM URL (где запущен vm/server.py) ───────────────────────────
VM_URL=http://localhost:5001

# ── AI Backend URLs ───────────────────────────────────────────────────
# Ollama (установка: https://ollama.ai)
OLLAMA_URL=http://localhost:11434

# LM Studio (установка: https://lmstudio.ai)
LMS_URL=http://localhost:1234

# Text Generation WebUI (TGWUI)
# Docker: docker compose up tgwui -d
TGWUI_URL=http://localhost:5000

# Stable Diffusion WebUI (AUTOMATIC1111)
# Docker: docker compose up sd-webui -d
SD_URL=http://localhost:7860

# ComfyUI
# Docker: docker compose up comfyui -d
COMFYUI_URL=http://localhost:8188

# Open WebUI / OAF
# Docker: docker compose up ollama-webui -d
OAF_URL=http://localhost:3000

# TripoSR (3D generation)
TRIPOSR_URL=http://localhost:7861

# Roo Code API (если запущен)
ROOCODE_URL=http://localhost:1337

# Vision VM URL (отдельная VM с vision-моделями)
VISION_VM_URL=http://localhost:8080

# Remote VM URL (оставьте пустым если нет)
REMOTE_VM_URL=

# ── AI timeout (секунды) ──────────────────────────────────────────────
AI_TIMEOUT=120

# ── HuggingFace (опционально) ─────────────────────────────────────────
# HUGGINGFACE_API_KEY=hf_...
