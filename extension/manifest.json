{
  "manifest_version": 3,
  "name": "DRGR Bot Control",
  "version": "1.0",
  "description": "Управление DRGR VM и ботом прямо из браузера",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ]
}
