{
  "manifest_version": 3,
  "name": "DRGR Bot",
  "version": "1.0",
  "description": "Быстрый доступ к DRGR Bot – локальному AI-помощнику (localhost:5001)",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DRGR Bot"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"]
}
